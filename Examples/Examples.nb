           RowBox[{"-", "1"}], "+", 
           RowBox[{"2", " ", "\[Nu]"}]}], "]"}]}], 
        RowBox[{
         RowBox[{"Gamma", "[", "\[Nu]", "]"}], " ", "q"}]], "-", 
