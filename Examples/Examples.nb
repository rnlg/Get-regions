        Gamma[$CellContext`\[Nu]]^(-1) 
        Gamma[Rational[-3, 2] + 2 $CellContext`\[Nu]], 
        0, -2^(-1 + 2 $CellContext`\[Nu]) Gamma[(-2) $CellContext`\[Nu]] 
