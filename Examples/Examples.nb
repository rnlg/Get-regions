    SeriesData[$CellContext`q, 
     0, {(-1 + $CellContext`\[Nu])^(-1), (-2)/(2 - 
      3 $CellContext`\[Nu] + $CellContext`\[Nu]^2), 
      12 $CellContext`\[Nu] (1 + $CellContext`\[Nu]) 
      Gamma[-3 + $CellContext`\[Nu]]/Gamma[2 + $CellContext`\[Nu]]}, 0, 3, 1],
    
    Editable->False], ",", 
   RowBox[{
    SuperscriptBox["q", "\[Nu]"], " ", 
    RowBox[{"(", 
     InterpretationBox[
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"Gamma", "[", 
          RowBox[{"1", "-", "\[Nu]"}], "]"}], " ", 
         RowBox[{"Gamma", "[", 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           RowBox[{"2", " ", "\[Nu]"}]}], "]"}]}], 
        RowBox[{
         RowBox[{"Gamma", "[", "\[Nu]", "]"}], " ", "q"}]], "-", 
       FractionBox[
        RowBox[{
         SuperscriptBox["4", "\[Nu]"], " ", "\[Nu]", " ", 
         RowBox[{"Gamma", "[", 
          RowBox[{"-", "\[Nu]"}], "]"}], " ", 
         RowBox[{"Gamma", "[", 
          RowBox[{
           FractionBox["1", "2"], "+", "\[Nu]"}], "]"}]}], 
        SqrtBox["\[Pi]"]], "+", 
       FractionBox[
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", "+", "\[Nu]", "-", 
           RowBox[{"16", " ", 
            SuperscriptBox["\[Nu]", "2"]}]}], ")"}], " ", 
