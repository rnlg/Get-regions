RowBox[{\\\"0.`\\\", \\\",\\\", \\\"2.337279285007143`*^-135\\\"}], \
\\\"}\\\"}], \\\",\\\", RowBox[{\\\"{\\\", RowBox[{\\\"0\\\", \\\",\\\", \
