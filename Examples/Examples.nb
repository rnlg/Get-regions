Cell[BoxData[
 RowBox[{"contribs", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Series", "[", 
      RowBox[{
       RowBox[{"Coefficient", "[", 
        RowBox[{
         RowBox[{
          FractionBox[
           RowBox[{"Dt", "[", "x", "]"}], 
