           RowBox[{"-", "1"}], "+", 
           RowBox[{"2", " ", "\[Nu]"}]}], "]"}]}], 
        RowBox[{
         RowBox[{"Gamma", "[", "\[Nu]", "]"}], " ", "q"}]], "-", 
       FractionBox[
        RowBox[{
         SuperscriptBox["4", "\[Nu]"], " ", "\[Nu]", " ", 
