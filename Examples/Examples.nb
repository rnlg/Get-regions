Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    RowBox[{
     FractionBox["1", 
      RowBox[{
       RowBox[{"-", "1"}], "+", "\[Nu]"}]], "-", 
     FractionBox[
      RowBox[{"2", " ", "q"}], 
      RowBox[{"2", "-", 
       RowBox[{"3", " ", "\[Nu]"}], "+", 
       SuperscriptBox["\[Nu]", "2"]}]], "+", 
     FractionBox[
      RowBox[{"12", " ", "\[Nu]", " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", "\[Nu]"}], ")"}], " ", 
       RowBox[{"Gamma", "[", 
