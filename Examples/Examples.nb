Cell[TextData[{
 "E.g., {-5, {-3}} corresponds to the region where ",
 Cell[BoxData[
  FormBox[
   StyleBox["x", "TI"], TraditionalForm]],ExpressionUUID->
  "7db9f4e1-852a-4f87-b60b-fa97f6c8f085"],
 " scales as ",
