      12 $CellContext`\[Nu] (1 + $CellContext`\[Nu]) 
      Gamma[-3 + $CellContext`\[Nu]]/Gamma[2 + $CellContext`\[Nu]]}, 0, 3, 1],
    
    Editable->False], ",", 
   RowBox[{
    SuperscriptBox["q", "\[Nu]"], " ", 
    RowBox[{"(", 
     InterpretationBox[
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"Gamma", "[", 
          RowBox[{"1", "-", "\[Nu]"}], "]"}], " ", 
