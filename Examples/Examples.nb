       "q"}], 
      RowBox[{"4", " ", 
       RowBox[{"Gamma", "[", "\[Nu]", "]"}]}]], "+", 
     FractionBox[
      RowBox[{"3", " ", "\[Pi]", " ", 
       RowBox[{"Gamma", "[", 
        RowBox[{
         RowBox[{"-", "2"}], "+", "\[Nu]"}], "]"}], " ", 
       SuperscriptBox["q", "2"]}], 
      RowBox[{"16", " ", 
       RowBox[{"Gamma", "[", "\[Nu]", "]"}]}]], "+", 
     InterpretationBox[
      SuperscriptBox[
       RowBox[{"O", "[", "q", "]"}], "3"],
      SeriesData[$CellContext`q, 0, {}, 0, 3, 1],
      Editable->False]}],
    SeriesData[$CellContext`q, 0, {
     Rational[1, 4] (Pi/(-1 + $CellContext`\[Nu])), Rational[-1, 4] 
