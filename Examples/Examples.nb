          RowBox[{"-", "\[Nu]"}], "]"}], " ", 
         RowBox[{"Gamma", "[", 
          RowBox[{
           FractionBox["1", "2"], "+", "\[Nu]"}], "]"}]}], 
        SqrtBox["\[Pi]"]], "+", 
       FractionBox[
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", "+", "\[Nu]", "-", 
           RowBox[{"16", " ", 
            SuperscriptBox["\[Nu]", "2"]}]}], ")"}], " ", 
         RowBox[{"Gamma", "[", 
          RowBox[{"2", "-", "\[Nu]"}], "]"}], " ", 
         RowBox[{"Gamma", "[", 
          RowBox[{
           RowBox[{"-", "2"}], "+", 
