      RowBox[{"2", " ", "q"}], 
      RowBox[{"2", "-", 
       RowBox[{"3", " ", "\[Nu]"}], "+", 
       SuperscriptBox["\[Nu]", "2"]}]], "+", 
     FractionBox[
      RowBox[{"12", " ", "\[Nu]", " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", "\[Nu]"}], ")"}], " ", 
       RowBox[{"Gamma", "[", 
        RowBox[{
         RowBox[{"-", "3"}], "+", "\[Nu]"}], "]"}], " ", 
       SuperscriptBox["q", "2"]}], 
      RowBox[{"Gamma", "[", 
       RowBox[{"2", "+", "\[Nu]"}], "]"}]], "+", 
     InterpretationBox[
      SuperscriptBox[
       RowBox[{"O", "[", "q", "]"}], "3"],
      SeriesData[$CellContext`q, 0, {}, 0, 3, 1],
