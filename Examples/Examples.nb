Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    SuperscriptBox["q", 
     RowBox[{
      RowBox[{"-", "3"}], "+", 
      RowBox[{"5", " ", "\[Nu]"}]}]], " ", 
    RowBox[{"(", 
     InterpretationBox[
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"Gamma", "[", 
          RowBox[{"1", "-", 
           RowBox[{"2", " ", "\[Nu]"}]}], "]"}], " ", 
         RowBox[{"Gamma", "[", 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           RowBox[{"3", " ", "\[Nu]"}]}], "]"}]}], 
        RowBox[{"Gamma", "[", "\[Nu]", "]"}]], "-", 
