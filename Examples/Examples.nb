       RowBox[{"{", 
        RowBox[{"q", ",", "0", ",", "2"}], "}"}]}], "]"}], "&"}], "/@", 
    "regions"}], "/.", 
   RowBox[{
    RowBox[{"sd", ":", 
     RowBox[{"HoldPattern", "[", 
      RowBox[{"SeriesData", "[", 
       RowBox[{"q", ",", "0", ",", "__"}], "]"}], "]"}]}], ":>", 
    RowBox[{"MapAt", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Integrate", "[", 
        RowBox[{"#", ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "0", ",", "\[Infinity]"}], "}"}], ",", 
         RowBox[{"GenerateConditions", "->", "False"}]}], "]"}], "&"}], ",", 
      "sd", ",", 
