          RowBox[{"1", "-", "\[Nu]"}], "]"}], " ", 
         RowBox[{"Gamma", "[", 
          RowBox[{"2", " ", "\[Nu]"}], "]"}], " ", 
         SuperscriptBox["q", "2"]}], 
        RowBox[{"3", " ", 
         RowBox[{"Gamma", "[", 
          RowBox[{"2", "+", "\[Nu]"}], "]"}]}]], "+", 
       InterpretationBox[
        SuperscriptBox[
         RowBox[{"O", "[", "q", "]"}], "3"],
        SeriesData[$CellContext`q, 0, {}, -1, 3, 1],
        Editable->False]}],
      SeriesData[$CellContext`q, 0, {
       Gamma[1 - $CellContext`\[Nu]] Gamma[$CellContext`\[Nu]]^(-1) 
        Gamma[-1 + 2 $CellContext`\[Nu]], -4^$CellContext`\[Nu] 
