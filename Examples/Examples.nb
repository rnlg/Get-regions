Cell[CellGroupData[{

Cell["Integral convergence", "Section",
 CellChangeTimes->{{3.978942993607234*^9, 
  3.978942999702572*^9}},ExpressionUUID->"13d2134d-5b85-4bd0-9af1-\
c951be0c1dab"],

Cell[TextData[{
 "Suppose that we want to determine when the integral ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         UnderoverscriptBox[
         "\[Integral]", "0", "\[Infinity]", LimitsPositioning -> True], 
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["x", "TI"], 
            StyleBox["d", "TI"], 
            StyleBox["y", "TI"], 
            SuperscriptBox[
             StyleBox["x", "TI"], 
             RowBox[{
               StyleBox["n", "TI"], "-", "1"}]], 
            SuperscriptBox[
             StyleBox["y", "TI"], 
             RowBox[{
               StyleBox["m", "TI"], "-", "1"}]]}], 
          RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
               RowBox[{"1", "+", 
                 StyleBox["x", "TI"], "+", 
                 StyleBox["y", "TI"]}], ")"}], 
             StyleBox["a", "TI"]], 
            SuperscriptBox[
             RowBox[{"(", 
               RowBox[{"1", "+", 
                 StyleBox["x", "TI"], 
                 StyleBox["y", "TI"], "+", 
                 SuperscriptBox[
                  StyleBox["x", "TI"], "2"]}], ")"}], 
             StyleBox["b", "TI"]]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "\\intop_0^\\infty \\frac{dxdy x^{n-1}y^{m-1}}{(1+x+y)^a (1+x y+x^2)^b}",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d7419691-9345-444d-90e8-673c7cef74c2"],
 " converges. We have"
}], "Text",
 CellChangeTimes->{{3.97894951714076*^9, 3.978949535134993*^9}, 
   3.978949575128615*^9, {3.978949645720374*^9, 
   3.978949656091495*^9}},ExpressionUUID->"242b41a9-3398-4526-85d2-\
eccfc5878d22"],

