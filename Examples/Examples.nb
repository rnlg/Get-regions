          RowBox[{"2", "-", "\[Nu]"}], "]"}], " ", 
         RowBox[{"Gamma", "[", 
          RowBox[{
           RowBox[{"-", "2"}], "+", 
           RowBox[{"2", " ", "\[Nu]"}]}], "]"}], " ", "q"}], 
        RowBox[{"Gamma", "[", "\[Nu]", "]"}]], "+", 
       FractionBox[
        RowBox[{"\[Nu]", " ", 
         RowBox[{"(", 
          RowBox[{"1", "+", "\[Nu]"}], ")"}], " ", 
